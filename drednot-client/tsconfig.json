{
  "extends": "../tsconfig.base.json",
  "compilerOptions": {
    "lib": ["ES2023", "DOM", "DOM.Iterable"],
    "noEmit": true,
    "allowJs": true,
    "checkJs": true,
    "paths": {
      "@DClient/*": ["./src/*"],
      "@/*": ["../src/*"],
      "@utilities/*": ["../src/utilities/*"],
      "@environment": ["../src/environment.ts"],
      "@configs": ["../src/configs/index.ts"],
      "@configs/*": ["../src/configs/*"],
      "@commands/*": ["../src/commands/*"],
      "@legacyCommands/*": ["../src/commands/legacyCommands/*"],
      "@slashCommands/*": ["../src/commands/slashCommands/*"],
      "@services/*": ["../src/services/*"],
      "@handlers/*": ["../src/handlers/*"],
      "@events/*": ["../src/events/*"],
      "@Rmigrations/*": ["../src/migrations/*"],
      "@dependencies": ["../src/commands/dependencies.ts"],
      "@dependency/*": ["../src/commands/dependency/*"],
      "@modules/*": ["../src/modules/*"],
      "@databases/*": ["../src/databases/*"],
      "@getDatabase": ["../src/databases/index.ts"],
      "@tables/*": ["../src/databases/tables/*"],
      "@Dmigrations/*": ["../src/databases/migrations/*"],
      "@backend/*": ["../src/backend/*"],
      "@backend/config": ["../src/backend/utils/config.ts"]
    }
  },
  "include": [
    "src/**/*.ts",
    "esbuild.mjs",
    "../src/backend/**/*.ts"
  ],
  "exclude": [
    "node_modules",
    "dist",
    "data",
    "assets",
    "logs",
    ".cache",
    "bundled"
  ]
}
