{
  "extends": "../tsconfig.base.json",
  "compilerOptions": {
    "rootDir": "./",
    "outDir": "./bundled",

    "lib": ["ES2023", "DOM", "DOM.Iterable"],

    "noEmit": true,

    "allowJs": true,
    "checkJs": true,

    "paths": {
      "@DClient/*": ["./src/*"]
    }
  },
  "include": ["src/**/*.ts", "esbuild.mjs"],
  "exclude": ["node_modules", "dist", "data", "assets", "logs", ".cache"]
}
