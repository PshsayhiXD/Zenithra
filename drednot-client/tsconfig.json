{
  "extends": "../tsconfig.base.json",
  "compilerOptions": {
    "lib": ["ES2023", "DOM", "DOM.Iterable"],
    "noEmit": true,
    "allowJs": true,
    "checkJs": true,
    "paths": {
      "@DClient/*": ["./src/*"],
      "@backend/*": ["../src/backend/*"],
      "@backend/config": ["../src/backend/utils/config.ts"]
    }
  },
  "include": [
    "src/**/*.ts",
    "esbuild.mjs",
    "../src/backend/**/*.ts"
  ],
  "exclude": [
    "node_modules",
    "dist",
    "data",
    "assets",
    "logs",
    ".cache"
  ]
}
