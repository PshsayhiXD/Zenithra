{
  "type": "commonjs",
  "scripts": {
    "dev": "npm run dev:bot",
    "dev:bot": "tsx watch src/bot.ts",
    "dev:bot:debug": "NODE_OPTIONS=--enable-source-maps tsx watch --inspect src/bot.ts",
    "dev:debug": "npm run dev:bot:debug",
    "dev:shard": "tsx watch src/sharding.ts",
    "dev:shard:debug": "NODE_OPTIONS=--enable-source-maps tsx watch --inspect src/sharding.ts",
    "test": "npm run check && npm run build",
    "build": "tsc && tsc-alias",
    "build:clean": "npm run clean && npm run build && npm run db:copy",
    "build:prod": "npm run build:clean",
    "build:client": "node drednot-client/esbuild.mjs",
    "build:client:watch": "node drednot-client/esbuild.mjs --watch",
    "start": "npm run start:shard && npm run start:server",
    "start:bot": "node dist/bot.js",
    "start:bot:debug": "node --enable-source-maps --inspect dist/bot.js",
    "start:debug": "npm run start:bot:debug",
    "start:shard": "node dist/sharding.js",
    "start:shard:debug": "node --enable-source-maps --inspect dist/sharding.js",
    "start:prod": "npm run start",
    "start:server": "node src/backend.ts",
    "clean": "node script/clean.mjs",
    "db:copy": "node script/copyDatabase.mjs",
    "env:copy": "node script/copyEnv.js",
    "lint": "eslint src",
    "lint:debug": "eslint src --debug",
    "lint:fix": "eslint src --fix",
    "typecheck": "tsc --noEmit",
    "check": "npm run lint && npm run typecheck",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "fix": "npm run lint:fix && npm run format",
    "validate": "npm run check && npm run format:check",
    "ci": "npm test",
    "pm2:start": "pm2 start ecosystem.config.cjs",
    "pm2:restart": "pm2 restart ecosystem.config.cjs --update-env",
    "pm2:stop": "pm2 stop dredbot-evolve",
    "pm2:logs": "pm2 logs dredbot-evolve --raw"
  },
  "dependencies": {
    "@msgpack/msgpack": "^3.1.3",
    "better-sqlite3": "^12.8.0",
    "decimal.js": "^10.6.0",
    "discord.js": "^14.26.0",
    "dotenv": "^17.4.0",
    "http-proxy": "^1.18.1",
    "https-proxy-agent": "^9.0.0",
    "localtunnel": "^2.0.2",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "pino-roll": "^4.0.0",
    "sharp": "^0.34.5",
    "ws": "^8.20.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/better-sqlite3": "^7.6.13",
    "@types/http-proxy": "^1.17.17",
    "@types/localtunnel": "^2.0.4",
    "@types/node": "^25.6.0",
    "esbuild": "^0.25.12",
    "eslint": "^10.2.0",
    "eslint-import-resolver-typescript": "^4.4.4",
    "eslint-plugin-import-x": "^4.16.2",
    "eslint-plugin-unicorn": "^64.0.0",
    "tsc-alias": "^1.8.16",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2",
    "typescript-eslint": "^8.58.0"
  }
}
