{
  "type": "commonjs",
  "scripts": {
    "mkcert": "node ./script/mkcert.mjs",

    "build": "tsc && tsc-alias",
    "build:cleanDist": "npm run cleanDist && npm run build && npm run db:copy",
    "build:prod": "npm run build:cleanDist && npm run build:client && npm run build:frontend",
    "build:client": "node drednot-client/esbuild.mjs",
    "build:client:watch": "node drednot-client/esbuild.mjs --watch",
    "build:frontend": "node src/frontend/esbuild.mjs",
    "build:frontend:dev": "node src/frontend/esbuild.mjs --dev",
    "build:frontend:watch": "node src/frontend/esbuild.mjs --watch --dev",

    "start": "npm run start:shard && npm run start:server",
    "start:bot": "node dist/bot.js",
    "start:bot:debug": "node --enable-source-maps --inspect dist/bot.js",
    "start:debug": "npm run start:bot:debug",
    "start:shard": "node dist/sharding.js",
    "start:shard:debug": "node --enable-source-maps --inspect dist/sharding.js",
    "start:prod": "npm run start",
    "start:server": "node dist/backend.js",
    "cleanDist": "node script/clean.mjs",

    "db:copy": "node script/copyDatabase.mjs",
    "env:copy": "node script/copyEnvironment.mjs",

    "lint": "eslint src drednot-client",
    "lint:debug": "eslint src drednot-client --debug",
    "lint:fix": "eslint src drednot-client --fix",

    "typecheck": "tsc --noEmit && tsc -p drednot-client/tsconfig.json --noEmit && tsc -p src/frontend/tsconfig.json --noEmit",
    "typecheck:bot": "tsc --noEmit",
    "typecheck:client": "tsc -p drednot-client/tsconfig.json --noEmit",
    "typecheck:frontend": "tsc -p src/frontend/tsconfig.json --noEmit",

    "react:doctor": "react-doctor .",
    "react:doctor:debug": "react-doctor . --verbose",
    "check": "npm run lint && npm run typecheck",

    "pm2:start": "pm2 start ecosystem.config.cjs",
    "pm2:restart": "pm2 restart ecosystem.config.cjs --update-env",
    "pm2:stop": "pm2 stop zenithra",
    "pm2:logs": "pm2 logs zenithra --raw"
  },
  "dependencies": {
    "@msgpack/msgpack": "^3.1.3",
    "@ngrok/ngrok": "^1.7.0",
    "better-sqlite3": "^12.8.0",
    "decimal.js": "^10.6.0",
    "discord.js": "^14.26.4",
    "dotenv": "^17.4.0",
    "http-proxy": "^1.18.1",
    "https-proxy-agent": "^9.0.0",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "pino-roll": "^4.0.0",
    "sharp": "^0.34.5",
    "ws": "^8.20.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@tailwindcss/postcss": "^4.1.8",
    "@types/better-sqlite3": "^7.6.13",
    "@types/http-proxy": "^1.17.17",
    "@types/node": "^25.6.0",
    "@types/react": "^19.1.6",
    "@types/react-dom": "^19.1.5",
    "esbuild": "^0.25.12",
    "eslint": "^10.2.0",
    "eslint-import-resolver-typescript": "^4.4.4",
    "eslint-plugin-import-x": "^4.16.2",
    "eslint-plugin-unicorn": "^64.0.0",
    "postcss": "^8.5.4",
    "react": "^19.1.0",
    "react-doctor": "^0.2.1",
    "react-dom": "^19.1.0",
    "tailwindcss": "^4.1.8",
    "tsc-alias": "^1.8.16",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2",
    "typescript-eslint": "^8.58.0"
  }
}
